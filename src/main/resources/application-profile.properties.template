#Global configuration
#spring.profiles.active=setYourProfileName

#False for dev mod only
spring.thymeleaf.cache=true 

#Tomcat configuration
server.port=9002
 
#Log level configuration
logging.level.fr.ses10doigts==INFO
  
#Mysql Config
spring.jpa.hibernate.ddl-auto=update
spring.datasource.username=setYourDBUserName
spring.datasource.password=setYourDBPassword

# Optionnel : uniquement si ce profil sert des fichiers statiques depuis un chemin non
# embarque dans le jar (voir application-prod.properties).
#spring.web.resources.static-locations=file:/path/to/static/files

#Telegram bot
fr.ses10doigts.crawler.botToken=token...
fr.ses10doigts.crawler.botUsername=botname...

# App Properties (JWT - Spring Security)
bezkoder.app.jwtCookieName=setYourCookieName
bezkoder.app.jwtSecret=setYourJwtSecret
bezkoder.app.jwtExpirationMs=86400000

# OpenAI
tradeio.openai.apiKey=yourKey
# Mapping niveau logique -> modele concret. LOW obligatoire (utilise en repli si MEDIUM/HIGH absents) ;
# MEDIUM/HIGH optionnels (voir LlmTier / OpenAIService#resolveModel pour la logique de repli).
tradeio.openai.model.low=GPT_4_1_MINI
tradeio.openai.model.medium=GPT_4_1
tradeio.openai.model.high=GPT_5_5
tradeio.openai.baseUrl=https://api.openai.com/v1

# Clé generee manuellement sur https://coinalyze.net/account/api-key/ (compte gratuit). Voir
# ApiCredentialInitializer#run : sans cette valeur, aucune credential COINALYZE n'est creee pour
# l'utilisateur System et OPEN_INTEREST/FUNDING_RATE/LIQUIDATIONS restent invalid.
tradeio.coinalyze.apiKey=yourKey

# Clé generee manuellement sur https://twelvedata.com (compte gratuit). Sans cette valeur, DXY/SP500/NASDAQ restent
# invalid (voir ApiCredentialInitializer#run).
tradeio.twelvedata.apiKey=yourKey

# Clé generee manuellement sur https://finnhub.io (compte gratuit) Sans cette valeur, le calendrier macro
# (MacroEventCalendarService) se limite a ForexFactory (voir ApiCredentialInitializer#run).
tradeio.finnhub.apiKey=yourKey

# Clé CoinStats (compte System). Sans cette valeur, aucune credential COINSTATS n'est
# creee et FEAR_GREED reste invalid (voir ApiCredentialInitializer#run).
tradeio.coinstats.apiKey=yourKey

# Clé generee via inscription gratuite sur https://sosovalue.com/developer (palier "Demo",
# 20 appels/min). Voir ApiCredentialInitializer#run : sans cette valeur, aucune credential
# SOSOVALUE n'est creee pour l'utilisateur System et ETF_FLOW reste invalid.
tradeio.sosovalue.apiKey=yourKey